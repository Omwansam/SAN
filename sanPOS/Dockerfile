# Build Vite app, then serve with nginx (reverse-proxy /api to the API service)
FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
# `npm install` (not ci): lock can omit optional platform-specific deps (e.g. @emnapi/* for Rolldow on Linux) that `npm ci` in Alpine then rejects.
RUN npm install --no-audit --no-fund

COPY . .

# Empty string = same-origin /api (via nginx) — required for IP-only VPS access
ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
