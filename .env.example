# Used by docker compose — copy to .env and fill in values
POSTGRES_USER=sanpos
POSTGRES_DB=sanpos
POSTGRES_PASSWORD=change_me_strong_password

JWT_SECRET=change_me_min_32_chars_random_string
JWT_EXPIRES_IN=7d

# Host port to bind (default 80). On Hostinger, open this in the firewall and use http://SERVER_IP
HTTP_PORT=80
