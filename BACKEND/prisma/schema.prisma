//////////////////////////////////////////////////////
// PRISMA SCHEMA
// Multi-tenant POS backend data model
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// PRISMA CLIENT GENERATOR
//////////////////////////////////////////////////////
generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////////////////////
// DATABASE CONNECTION
//////////////////////////////////////////////////////
datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS (FIXED VALUE SETS)
// These restrict fields to predefined values
//////////////////////////////////////////////////////

enum TenantStatus {
  active
  suspended
}

enum UserRole {
  cashier
  manager
  admin
  superadmin
}

enum RegisterStatus {
  open
  closed
}

enum OrderStatus {
  completed
  refunded
  cancelled
}

enum PaymentStatus {
  paid
  pending
  failed
}

enum PaymentMethod {
  cash
  card
  mpesa
  bank_transfer
  credit
}

enum PrepStatus {
  queued
  preparing
  ready
  served
}

enum ServiceMode {
  delivery
  dine_in
  takeaway
}

enum NotificationLevel {
  info
  success
  warning
  error
}

enum DiscountType {
  none
  percent
  flat
}

/// Workspace provisioning lifecycle (matches onboarding “Setting up” step when backed by jobs).
enum TenantProvisionStatus {
  pending
  provisioning
  ready
  failed
}

/// Billing cadence chosen during onboarding (step “Billing”).
enum BillingPlanInterval {
  monthly
  annual
}

/// UI step index in onboarding wizard.
enum OnboardingStep {
  create_account
  business_details
  billing
  verify_email
  setting_up
  completed
}

enum OnboardingStatus {
  in_progress
  completed
  abandoned
}

//////////////////////////////////////////////////////
// TENANCY CORE TABLES
//////////////////////////////////////////////////////

// TENANT TABLE
model Tenant {
  id                   String                @id @default(cuid())
  slug                 String                @unique
  businessName         String
  businessType         String
  status               TenantStatus          @default(active)
  /// Optional dedicated DB schema name for multi-tenant isolation (set after provisioning).
  schemaName           String?               @unique
  provisionStatus      TenantProvisionStatus @default(ready)
  provisionError       String?
  provisionStartedAt   DateTime?
  provisionCompletedAt DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  domains                     TenantDomain[]
  config                      TenantConfig?
  users                       User[]
  branches                    Branch[]
  registers                   Register[]
  categories                  Category[]
  products                    Product[]
  customers                   Customer[]
  orders                      Order[]
  stockLogs                   StockLog[]
  dispensing                  DispensingLog[]
  kitchenTickets              KitchenTicket[]
  tables                      DiningTable[]
  appointments                Appointment[]
  notifications               Notification[]
  heldCarts                   HeldCart[]
  authSessions                AuthSession[]
  runtimeState                TenantRuntimeState?
  draftCarts                  DraftCart[]
  emailVerificationChallenges EmailVerificationChallenge[]
  onboardingDrafts            OnboardingDraft[]
}

// TENANT DOMAIN TABLE
model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  domain    String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// TENANT CONFIG TABLE
model TenantConfig {
  id                    String               @id @default(cuid())
  tenantId              String               @unique
  logo                  String?
  primaryColor          String?              @default("#2563eb")
  timezone              String?              @default("Africa/Nairobi")
  language              String?              @default("en")
  currencyCode          String?              @default("KES")
  currencySymbol        String?              @default("KSh")
  currencyPosition      String?              @default("before")
  taxRate               Float                @default(0)
  taxLabel              String?              @default("VAT")
  receiptFooter         String?
  paymentMethods        Json?
  kitchenStations       Json?
  modules               Json?
  billing               Json?
  receipt               Json?
  roles                 Json?
  customFields          Json?
  deliveryFee           Int                  @default(0)
  /// Onboarding step 1 — industry label (e.g. “Retail”, “Pharmacy”).
  industry              String?
  /// Onboarding step 1 — company size band.
  businessSize          String?
  /// Onboarding step 1 — optional public website.
  website               String?
  /// After BusinessTypeSelection; false until user confirms vertical.
  businessTypeConfirmed Boolean              @default(false)
  /// Whether sample catalogue was requested at signup (BusinessTypeSelection reads this).
  includeSampleData     Boolean              @default(true)
  /// Set true after first business-type flow completes (seed / empty workspace).
  workspaceInitialized  Boolean              @default(false)
  /// When user accepted Terms / Privacy during onboarding.
  termsAcceptedAt       DateTime?
  /// When email OTP step was verified server-side.
  emailVerifiedAt       DateTime?
  /// Onboarding billing step: monthly vs annual (also mirrored inside `billing` JSON if present).
  billingPlanInterval   BillingPlanInterval?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// USER TABLE
//////////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  firstName    String?
  lastName     String?
  email        String
  /// E.164 or display form from onboarding phone picker (e.g. “+254 712345678”).
  phone        String?
  passwordHash String
  role         UserRole  @default(cashier)
  pin          String?
  active       Boolean   @default(true)
  lastLogin    DateTime?
  registerId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant                  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register                Register?         @relation(fields: [registerId], references: [id], onDelete: SetNull)
  userBranches            UserBranch[]
  orders                  Order[]           @relation("CashierOrders")
  stockLogs               StockLog[]
  authSessions            AuthSession[]
  onboardingDraftsCreated OnboardingDraft[] @relation("OnboardingCreatedAdmin")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([registerId])
}

//////////////////////////////////////////////////////
// BRANCH / ACCESS TABLES
//////////////////////////////////////////////////////

// BRANCH TABLE
model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  createdAt DateTime @default(now())

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userBranches   UserBranch[]
  orders         Order[]
  stockLogs      StockLog[]
  kitchenTickets KitchenTicket[]
  tables         DiningTable[]
  heldCarts      HeldCart[]
  runtimeStates  TenantRuntimeState[]
  draftCarts     DraftCart[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// USER BRANCH ACCESS TABLE (JOIN TABLE)
model UserBranch {
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
}

// REGISTER TABLE
model Register {
  id           String         @id @default(cuid())
  tenantId     String
  name         String
  openingFloat Int            @default(0)
  currentFloat Int            @default(0)
  status       RegisterStatus @default(open)
  cashierId    String?
  createdAt    DateTime       @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders        Order[]
  users         User[]
  runtimeStates TenantRuntimeState[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// CATALOG TABLES
//////////////////////////////////////////////////////

// CATEGORY TABLE
model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String?
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// PRODUCT TABLE
model Product {
  id               String   @id @default(cuid())
  tenantId         String
  categoryId       String?
  name             String
  description      String?
  sku              String?
  barcode          String?
  price            Int
  costPrice        Int?
  taxable          Boolean  @default(true)
  imageUrl         String?
  stock            Int      @default(0)
  lowStockAlert    Int      @default(0)
  unit             String?  @default("ea")
  variants         Json?
  active           Boolean  @default(true)
  controlled       Boolean  @default(false)
  kitchenStationId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  stockLogs  StockLog[]
  draftLines DraftCartLine[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([categoryId])
}

//////////////////////////////////////////////////////
// CUSTOMER & ORDER TABLES
//////////////////////////////////////////////////////

// CUSTOMER TABLE
model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  phone         String?
  email         String?
  loyaltyPoints Int      @default(0)
  totalSpend    Int      @default(0)
  tags          Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders           Order[]
  appointments     Appointment[]
  dispensing       DispensingLog[]
  activeDraftCarts DraftCart[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
}

// ORDER TABLE
model Order {
  id                String        @id @default(cuid())
  tenantId          String
  branchId          String?
  registerId        String?
  cashierId         String?
  customerId        String?
  customerName      String?
  status            OrderStatus   @default(completed)
  paymentStatus     PaymentStatus @default(paid)
  subtotal          Int
  taxAmount         Int           @default(0)
  discountAmount    Int           @default(0)
  taxableBase       Int           @default(0)
  total             Int
  change            Int           @default(0)
  receiptPrinted    Boolean       @default(false)
  notes             String?
  partial           Boolean       @default(false)
  tipsTotal         Int           @default(0)
  deliveryFeeAmount Int           @default(0)
  serviceMode       ServiceMode?
  serviceModeLabel  String?
  deliveryAddress   String?
  deliveryPhone     String?
  deliveryRider     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  register      Register?      @relation(fields: [registerId], references: [id], onDelete: SetNull)
  cashier       User?          @relation("CashierOrders", fields: [cashierId], references: [id], onDelete: SetNull)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      Payment[]
  kitchenTicket KitchenTicket?
  dispensing    DispensingLog?

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([branchId])
  @@index([registerId])
  @@index([cashierId])
  @@index([customerId])
}

// ORDER ITEM TABLE
model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  productId         String?
  name              String
  qty               Int
  unitPrice         Int
  discount          Int      @default(0)
  discountPercent   Float    @default(0)
  tax               Int      @default(0)
  total             Int
  rxNumber          String?
  prescriber        String?
  patientDOB        String?
  controlled        Boolean  @default(false)
  deaNumber         String?
  refillsAuthorized Int      @default(0)
  refillsRemaining  Int      @default(0)
  pickupVerified    Boolean  @default(false)
  pickupIdLast4     String?
  prescriptionNotes String?
  prescriptionImage String?
  createdAt         DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// PAYMENT TABLE
model Payment {
  id        String        @id @default(cuid())
  orderId   String
  method    PaymentMethod
  amount    Int
  reference String?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

//////////////////////////////////////////////////////
// OPERATIONS / LOG TABLES
//////////////////////////////////////////////////////

// STOCK LOG TABLE
model StockLog {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  productId   String?
  productName String?
  delta       Int
  reason      String
  userId      String?
  createdAt   DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([productId])
  @@index([userId])
}

// DISPENSING LOG TABLE
model DispensingLog {
  id         String   @id @default(cuid())
  tenantId   String
  orderId    String?  @unique
  cashierId  String?
  customerId String?
  createdAt  DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines    DispensingLine[]

  @@index([tenantId])
  @@index([cashierId])
  @@index([customerId])
}

// DISPENSING LINE TABLE
model DispensingLine {
  id                String  @id @default(cuid())
  dispensingLogId   String
  name              String
  qty               Int
  rxNumber          String?
  prescriber        String?
  patientDOB        String?
  controlled        Boolean @default(false)
  deaNumber         String?
  refillsAuthorized Int     @default(0)
  refillsRemaining  Int     @default(0)
  pickupVerified    Boolean @default(false)
  pickupIdLast4     String?

  dispensingLog DispensingLog @relation(fields: [dispensingLogId], references: [id], onDelete: Cascade)

  @@index([dispensingLogId])
}

//////////////////////////////////////////////////////
// KITCHEN / FLOOR / APPOINTMENT TABLES
//////////////////////////////////////////////////////

// KITCHEN TICKET TABLE
model KitchenTicket {
  id        String   @id @default(cuid())
  tenantId  String
  orderId   String   @unique
  branchId  String?
  status    String?  @default("preparing")
  createdAt DateTime @default(now())

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branch Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  items  KitchenTicketItem[]

  @@index([tenantId])
  @@index([branchId])
}

// KITCHEN TICKET ITEM TABLE
model KitchenTicketItem {
  id         String     @id @default(cuid())
  ticketId   String
  lineKey    String?
  productId  String?
  name       String
  qty        Int
  unitPrice  Int
  discount   Int        @default(0)
  tax        Int        @default(0)
  total      Int
  prepStatus PrepStatus @default(queued)
  stationId  String?    @default("hot")

  ticket KitchenTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// DINING TABLE LAYOUT TABLE
model DiningTable {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  label        String
  x            Float
  y            Float
  capacity     Int?
  status       String?
  orderId      String?
  currentTotal Int?     @default(0)
  serverName   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
}

// APPOINTMENT TABLE
model Appointment {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String?
  title           String
  startAt         DateTime
  endAt           DateTime
  backgroundColor String?  @default("#6366f1")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, startAt])
}

//////////////////////////////////////////////////////
// RUNTIME / SESSION / CART TABLES
//////////////////////////////////////////////////////

// NOTIFICATION TABLE
model Notification {
  id        String            @id @default(cuid())
  tenantId  String
  level     NotificationLevel @default(info)
  title     String?
  message   String?
  createdAt DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// HELD CART TABLE
model HeldCart {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  snapshot  Json
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
}

// AUTH SESSION TABLE
model AuthSession {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String?
  tokenHash String?
  userName  String?
  userEmail String?
  role      UserRole?
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

// TENANT RUNTIME STATE TABLE
model TenantRuntimeState {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  activeBranchId   String?
  activeRegisterId String?
  zReportClosed    Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activeBranch   Branch?   @relation(fields: [activeBranchId], references: [id], onDelete: SetNull)
  activeRegister Register? @relation(fields: [activeRegisterId], references: [id], onDelete: SetNull)

  @@index([activeBranchId])
  @@index([activeRegisterId])
}

// DRAFT CART TABLE
model DraftCart {
  id                 String       @id @default(cuid())
  tenantId           String
  branchId           String
  activeCustomerId   String?
  serviceMode        ServiceMode  @default(delivery)
  orderDiscountType  DiscountType @default(none)
  orderDiscountValue Float        @default(0)
  deliveryAddress    String?
  deliveryPhone      String?
  deliveryRiderName  String?
  updatedAt          DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  activeCustomer Customer?       @relation(fields: [activeCustomerId], references: [id], onDelete: SetNull)
  lines          DraftCartLine[]

  @@unique([tenantId, branchId])
  @@index([tenantId])
  @@index([activeCustomerId])
}

// DRAFT CART LINE TABLE
model DraftCartLine {
  id                String   @id @default(cuid())
  draftCartId       String
  productId         String?
  name              String
  qty               Int
  unitPrice         Int
  discount          Int      @default(0)
  discountPercent   Float    @default(0)
  note              String?
  controlled        Boolean  @default(false)
  rxNumber          String?
  prescriber        String?
  patientDOB        String?
  deaNumber         String?
  refillsAuthorized Int      @default(0)
  refillsRemaining  Int      @default(0)
  pickupVerified    Boolean  @default(false)
  pickupIdLast4     String?
  kitchenStationId  String?
  prescriptionNotes String?
  prescriptionImage String?
  createdAt         DateTime @default(now())

  draftCart DraftCart @relation(fields: [draftCartId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([draftCartId])
  @@index([productId])
}

//////////////////////////////////////////////////////
// ONBOARDING & AUTH SUPPORT TABLES
//////////////////////////////////////////////////////

// EMAIL VERIFICATION CHALLENGE TABLE
// Server-side OTP storage for onboarding verification (hash only).
model EmailVerificationChallenge {
  id           String    @id @default(cuid())
  email        String
  /// Intended workspace slug once registration completes (may be set before `Tenant` row exists).
  slug         String?
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  tenantId     String?
  createdAt    DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([email, slug])
  @@index([expiresAt])
  @@index([tenantId])
}

// AUTH LOGIN ATTEMPT TABLE
// Optional audit trail for password/PIN login attempts.
model AuthLoginAttempt {
  id            String   @id @default(cuid())
  workspaceSlug String
  identifier    String
  method        String
  success       Boolean
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([workspaceSlug, createdAt])
  @@index([createdAt])
}

// ONBOARDING DRAFT TABLE
// Persistent snapshot of the 5-step onboarding flow.
model OnboardingDraft {
  id          String           @id @default(cuid())
  status      OnboardingStatus @default(in_progress)
  currentStep OnboardingStep   @default(create_account)

  /// Step 0: account details
  adminFirstName  String?
  adminLastName   String?
  adminEmail      String
  phoneCountryIso String?   @default("KE")
  adminPhoneLocal String?
  adminPhoneFull  String?
  passwordHash    String?
  passwordScore   Int?
  termsAcceptedAt DateTime?

  /// Step 1: business details
  workspaceSlug   String?
  businessName    String?
  industry        String?
  businessSize    String?
  businessWebsite String?

  /// Step 2: billing selection
  billingPlanInterval BillingPlanInterval?
  trialEndsAt         DateTime?

  /// Step 3: email verification
  verificationCodeHash String?
  verificationSentAt   DateTime?
  resendCount          Int       @default(0)
  resendAvailableAt    DateTime?
  emailVerifiedAt      DateTime?

  /// Step 4: setup/provisioning progress shown in UI
  setupProgress     Int?      @default(50)
  setupMessageIndex Int?      @default(0)
  setupStartedAt    DateTime?
  setupCompletedAt  DateTime?

  /// Link to tenant once workspace is created.
  tenantId           String?
  createdAdminUserId String?
  completedAt        DateTime?
  abandonedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant           Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAdminUser User?   @relation("OnboardingCreatedAdmin", fields: [createdAdminUserId], references: [id], onDelete: SetNull)

  @@index([status, currentStep])
  @@index([adminEmail])
  @@index([workspaceSlug])
  @@index([tenantId])
  @@index([createdAdminUserId])
}
